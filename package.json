{
  "name": "aegis-t3",
  "version": "0.1.0",
  "private": true,
  "description": "Aegis — an autonomous healthcare claims & reimbursement agent built on Terminal 3 Agent Auth. The agent moves money and touches PHI, yet cannot be made to leak or steal.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "demo": "tsx src/demo.ts",
    "live:check": "tsx src/live-check.ts",
    "deploy:contract": "tsx src/deploy-contract.ts",
    "redteam": "tsx src/redteam/run.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@terminal3/t3n-sdk": "^3.9.0",
    "canonicalize": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "sharp": "^0.35.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
