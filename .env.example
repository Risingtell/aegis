# ── Terminal 3 credentials ──────────────────────────────────────────────
# Claim these (free, instant, self-serve) at https://www.terminal3.io/claim-page
# Sign in with your work email. The key is shown ONCE — copy it immediately.
#
# T3N_API_KEY is the ETH private key of the wallet you registered with.
# It never leaves your machine; it signs the login challenge locally.
T3N_API_KEY=

# Network: "testnet" (default) or "production".
T3N_ENV=testnet

# Optional: pin a specific node URL (otherwise the SDK uses the env default).
# T3N_NODE_URL=

# ── Agent runtime ───────────────────────────────────────────────────────
# When T3N_API_KEY is empty, Aegis runs fully against an in-memory mock of
# the T3N node (MockTransport) so the demo + red-team harness work offline.
# Set AEGIS_MODE=live to force live testnet (requires T3N_API_KEY).
# Set AEGIS_MODE=mock to force the offline simulator even if a key is present.
AEGIS_MODE=auto
